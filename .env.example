# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host/dbname

# API Server
PORT=3000
NODE_ENV=development

# Cloud Run (deployed)
# DEPLOYMENT_ENV=cloud-run

# Discord Webhook（ログ・通知）
DISCORD_WEBHOOK_ERRORS=https://discordapp.com/api/webhooks/YOUR_CHANNEL_ID/YOUR_TOKEN
